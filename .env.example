NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://openmantle_app:openmantle_app@postgres:5432/openmantle
REDIS_URL=redis://redis:6379
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ISSUER=openmantle
CORS_ORIGIN=http://localhost:3000
CREDENTIAL_ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key
PARTNER_API_VERSION=2026-07
PARTNER_API_REQUESTS_PER_SECOND=3
SUBSCRIPTION_POLL_INTERVAL_MS=300000
HISTORICAL_SYNC_INTERVAL_MS=900000
